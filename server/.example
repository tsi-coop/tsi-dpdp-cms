# .env.example
# This file serves as a template for the .env file, which should
# contain actual sensitive configuration and MUST NOT be committed to Git.
#
# To use: Copy this file to .env and fill in the placeholder values.

# --- Basic Configuration ---
JAVA_HOME=/usr/lib/jvm/java-1.17.0-openjdk-amd64
JETTY_HOME=
JETTY_BASE=

# --- Database Configuration ---
# Recommended: A strong, random password.
POSTGRES_HOST=jdbc:postgresql://localhost:5433
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWD=

# --- Application Configuration ---
# JWT_SECRET: minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=<generate-with-openssl-rand-hex-32>
# DB_ENCRYPTION_KEY: encrypts PII columns via pgcrypto. Never change after first use.
# Generate with: openssl rand -hex 32
DB_ENCRYPTION_KEY=<generate-with-openssl-rand-hex-32>
# TSI_LOOKUP_SALT: HMAC salt for pseudonymising user IDs in audit logs.
# Generate with: openssl rand -hex 32
TSI_LOOKUP_SALT=<generate-with-openssl-rand-hex-32>
TSI_DPDP_CMS_ENV=local
TSI_DPDP_CMS_HOME=
TSI_EXPORT_PATH=/var/lib/tsi/exports/

# --- White-labeling (optional) ---
# BRAND_NAME: partner/reseller brand shown throughout the UI instead of the
# default "TSI DPDP CMS". Max 12 characters — the app refuses to start if this
# is exceeded (the limit matches the default brand's length, so any compliant
# value is guaranteed to fit existing layouts without redesign).
# BRAND_NAME=Acme Privacy
