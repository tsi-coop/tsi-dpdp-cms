# .env.example

# --- Database Configuration ---
# Recommended: A strong, random password.
POSTGRES_HOST=jdbc:postgresql://localhost:5432
POSTGRES_DB=tsi_dpdp_cms
POSTGRES_USER=postgres
POSTGRES_PASSWD=<<password>>

# --- Application Configuration ---
# JWT_SECRET: minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=<<generate-with-openssl-rand-hex-32>>
# DB_ENCRYPTION_KEY: used by pgcrypto to encrypt PII columns (email, phone).
# Must match the value set in PostgreSQL via: ALTER DATABASE ... SET app.enc_key = '...';
# Generate with: openssl rand -hex 32  — never change after first use (data loss)
DB_ENCRYPTION_KEY=<<generate-with-openssl-rand-hex-32>>
# TSI_LOOKUP_SALT: HMAC salt for pseudonymising user IDs in audit logs.
# Generate with: openssl rand -hex 32
TSI_LOOKUP_SALT=<<generate-with-openssl-rand-hex-32>>
# ALLOWED_ORIGINS: comma-separated list of permitted origins for CORS
ALLOWED_ORIGINS=https://your-domain.com
TSI_DPDP_CMS_ENV=production
TSI_DPDP_CMS_HOME=/home/tsicoop/tsi-dpdp-cms
TSI_EXPORT_PATH=/var/lib/tsi/exports/
TSI_KEYSTORE_PATH=/var/lib/tsi/consentmgr.p12
TSI_KEYSTORE_PASS=<<keystore-password>>
TSI_KEYSTORE_ALIAS=abc-consentmgr
