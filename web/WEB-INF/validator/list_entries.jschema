{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ROPA List Entries",
  "type": "object",
  "properties": {
    "_func":        { "type": "string" },
    "fiduciary_id": { "type": "string" },
    "status":       { "type": "string" },
    "legal_basis":  { "type": "string" },
    "app_id":       { "type": "string" },
    "page":         { "type": "number" },
    "limit":        { "type": "number" }
  },
  "required": ["_func", "fiduciary_id"]
}
